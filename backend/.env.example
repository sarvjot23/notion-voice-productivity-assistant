# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_agent_id
ELEVENLABS_WEBHOOK_SECRET=your_shared_secret

# Todoist
TODOIST_API_TOKEN=your_todoist_api_token

# Google Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_TOKEN_FILE=.google_token.json

# Notion
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_NOTES_DATABASE_ID=your_notion_database_id

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_MEMORY_STORE_PATH=/webhook/memory/store
N8N_MEMORY_RETRIEVE_PATH=/webhook/memory/retrieve
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret
N8N_PASSWORD=your_n8n_admin_password

# Backend
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
